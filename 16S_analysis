*Differential Abundance*
**Aldex2**
#We will use the ALDEX2 differential abundance test. This approach takes read depth into account (which is why we did not rarify our reads earlier on). This test also accounts for compositionality, and is quite conservative and robust in how it subsamples our data to test each taxa.
```{r}
#create taxa info files
x <- subset_samples(ps1, depths != "D1")

if (!require('ALDEx2')) BiocManager::install("ALDEx2"); library('ALDEx2')
x=ps
taxa_info <- data.frame(tax_table(x))
taxa_info <- taxa_info %>% rownames_to_column(var = "OTU")

#this is to identify differences
reads<-data.frame(abundances(x))
conds<-sample_data(x)$depths #CHANGE TO THE SAMPLING GROUPING YOU WANT TO TEST!!!!!!!!

#Run ALDEx2 - this code does a clr transformation, then applies differential abundance testing and estimates effect sizes
#look at the documentation for this code. I'm running a T-test/wilcoxon test here but for more than two categorical variables you'll need to run kruskall-wallis tests ("kw")
aldex2_da <- aldex(reads, conds, test="t", effect = TRUE, verbose = TRUE, CI = FALSE, denom="all")
aldex2_output_OTU<-cbind(taxa_info,aldex2_da)
write.csv(aldex2_da, "path/to/file.csv") #Change with your desired file name
aldex.plot(aldex2_output_OTU, type = "volcano")
```

**ANCOM-BC**
#Analysis of Compositions of Microbiomes with Bias Correction 2 (ANCOM-BC2) is another popular differential abundance technique. Below we will use the global test function to generate: 1) test statistics; 2) p-values; 3) adjusted p-values; 4) indicators whether the taxon is differentially abundant (TRUE) or not (FALSE). 

```{r}
library(ANCOMBC)
library(DT)
#Set control as reference level
ps2 <- subset_samples(ps2, treatment != "Unveg_Tailings")
ps2@sam_data$treatment = factor(ps2@sam_data$treatment, levels = c("NT", "T"))

#Running ancombc2 for a phyloseq object
set.seed(123)
# It should be noted that we have set the number of bootstrap samples (B) equal 
# to 10 in the 'trend_control' function for computational expediency. 
# However, it is recommended that users utilize the default value of B, 
# which is 100, or larger values for optimal performance.
output = ancombc2(data = ps2, tax_level = "Genus",
                  fix_formula = "treatment + depth + time", rand_formula = NULL,
                  p_adj_method = "holm", pseudo_sens = TRUE,
                  prv_cut = 0.10, lib_cut = 1000, s0_perc = 0.05,
                  group = "treatment", struc_zero = TRUE, neg_lb = TRUE,
                  alpha = 0.05, n_cl = 2, verbose = TRUE,
                  global = TRUE, pairwise = TRUE, dunnet = TRUE, trend = TRUE,
                  iter_control = list(tol = 1e-2, max_iter = 20, 
                                      verbose = TRUE),
                  em_control = list(tol = 1e-5, max_iter = 100),
                  lme_control = lme4::lmerControl(),
                  mdfdr_control = list(fwer_ctrl_method = "holm", B = 100),
                  trend_control = list(contrast = list(matrix(c(1, 0, -1, 1),
                                                              nrow = 2, 
                                                              byrow = TRUE),
                                                       matrix(c(-1, 0, 1, -1),
                                                              nrow = 2, 
                                                              byrow = TRUE),
                                                       matrix(c(1, 0, 1, -1),
                                                              nrow = 2, 
                                                              byrow = TRUE)),
                                       node = list(2, 2, 1),
                                       solver = "ECOS",
                                       B = 10))
res_prim = output$res

#Plotting significant taxa
df_treatment = res_prim %>%
    dplyr::select(taxon, contains("treatment")) 
df_fig_treatment1 = df_treatment %>%
    dplyr::filter(diff_treatmentT == 1) %>%
    dplyr::mutate(lfc1 = ifelse(diff_treatmentT == 1, 
                                round(lfc_treatmentT, 2), 0)) %>%
    tidyr::pivot_longer(cols = lfc1, 
                        names_to = "group", values_to = "value") %>%
    dplyr::arrange(taxon)

df_fig_treatment2 = df_treatment %>%
    dplyr::filter(diff_treatmentT == 1) %>%
    dplyr::mutate(lfc1 = ifelse(diff_robust_treatmentT, 
                                "aquamarine3", "black")) %>%
    tidyr::pivot_longer(cols = lfc1, 
                        names_to = "group", values_to = "color") %>%
    dplyr::arrange(taxon)

df_fig_treatment = df_fig_treatment1 %>%
    dplyr::left_join(df_fig_treatment2, by = c("taxon", "group"))

df_fig_treatment$group = recode(df_fig_treatment$group, 
                          `lfc1` = "T - Tailings")
df_fig_treatment$group = factor(df_fig_treatment$group, 
                          levels = c("T - Tailings"))
  
lo = floor(min(df_fig_treatment$value))
up = ceiling(max(df_fig_treatment$value))
mid = (lo + up)/2
fig_treatment = df_fig_treatment %>%
  ggplot(aes(x = group, y = taxon, fill = value)) + 
  geom_tile(color = "black") +
  scale_fill_gradient2(low = "blue", high = "red", mid = "white", 
                       na.value = "white", midpoint = mid, limit = c(lo, up),
                       name = NULL) +
  geom_text(aes(group, taxon, label = value, color = color), size = 4) +
  scale_color_identity(guide = "none") +
  labs(x = NULL, y = NULL, title = "Log fold changes as compared to control samples") +
  theme_minimal() +
  theme(plot.title = element_text(hjust = 0.5))
fig_treatment
```

