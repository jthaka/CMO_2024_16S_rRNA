rarecurve(seqtab.nochim, step=100, cex=0.5, lwd=2, ylab="ASVs", label=F, col = as.vector(colorid$colour))
abline(v=(min(rowSums((seqtab.nochim))))) #Add a vertical line to plate where the fewest #sequences/sample occurs.
# Add a legend
legend(
  "bottomright",                           # placement
  legend = group_names, # labels for samples (or groups)
  col = as.vector(group_colours),        # same colours used above
  lty = 1,                                 # line type matches rarecurve
  cex = 0.8,                               # text size
  bty = "n"                                # no box around legend
)
